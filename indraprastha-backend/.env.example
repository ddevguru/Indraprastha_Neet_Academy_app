DATABASE_URL=
# Or use separate vars (when DATABASE_URL is not set):
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

NODE_ENV=production
GCP_PROJECT_ID=

JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
CORS_ORIGINS=

# Rate limit (global). Defaults: 300 requests / 15 minutes.
# For Loader.io medium load tests, temporarily raise then restore:
#   RATE_LIMIT_MAX=50000
#   RATE_LIMIT_WINDOW_MS=900000
# After tests, set RATE_LIMIT_MAX=300 again and redeploy.
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=900000

# Loader.io host verification for api.indraprasthaneetacademy.com
# 1) In loader.io → New Host → copy token (loaderio-xxxxxxxx)
# 2) Set LOADER_IO_TOKEN to that exact value and redeploy
# 3) Verify: https://api.indraprasthaneetacademy.com/<token>.txt
# 4) In loader.io click Verify
LOADER_IO_TOKEN=

# Razorpay (INDRAPRASTHA NEET ACADEMY PRIVATE LIMITED)
